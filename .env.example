# === VAULT ===
# Ruta absoluta a tu vault de Obsidian
VAULT_PATH=/ruta/a/tu/obsidian/vault

# === TELEGRAM ===
# Token de @BotFather
TELEGRAM_BOT_TOKEN=tu_token_aqui
# Tu ID de usuario de Telegram para restringir el acceso (puedes obtenerlo hablando con el bot)
TELEGRAM_ALLOWED_USER_ID=tu_id_aqui

# === OPENCODE ===
# Puerto para el servidor del agente
OPENCODE_PORT=4096
# Identificador de sesión para PERSISTENCIA de memoria
OPENCODE_SESSION_ID=assistant-session

# === GITHUB ===
# URL SSH de tu repo de backup (ej: git@github.com:usuario/repo.git)
GH_REMOTE=git@github.com:usuario/mi-vault-backup.git
